<% 
  var user = locals.userName || 'User';
  var bank = locals.bankName || 'Bank';
  var newPrinc = locals.newPrincipal || '0';
  var rate = locals.interestRate || '0';
  var newMatDate = locals.newMaturityDate || '';
%>
<h2 style="color: #1e293b; font-size: 22px; font-weight: 700; margin-top: 0; margin-bottom: 12px; text-align: center; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">🏦 FD Auto-Renewed</h2>
<p style="color: #475569; font-size: 15px; line-height: 1.6; margin-bottom: 24px; text-align: center; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  Hello <strong><%= user %></strong>,<br>
  Your Fixed Deposit at <strong><%= bank %></strong> has been automatically renewed.
</p>

<!-- Success Badge -->
<table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 24px;">
  <tr>
    <td align="center">
      <div style="background-color: #f0fdf4; display: inline-block; padding: 12px 24px; border-radius: 12px; border: 1px solid #bbf7d0;">
        <span style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 700; color: #059669; letter-spacing: 0.5px;">
          ✓ Renewed Successfully
        </span>
      </div>
    </td>
  </tr>
</table>

<div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 18px; margin-bottom: 24px;">
  <table border="0" cellpadding="0" cellspacing="0" width="100%" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; color: #475569;">
    <tr>
      <td style="padding: 6px 0; font-weight: 600; width: 50%;">Bank</td>
      <td style="padding: 6px 0; text-align: right;"><%= bank %></td>
    </tr>
    <tr>
      <td style="padding: 6px 0; border-top: 1px solid #e2e8f0; font-weight: 600;">New Principal</td>
      <td style="padding: 6px 0; border-top: 1px solid #e2e8f0; text-align: right; font-weight: 700;">₹<%= newPrinc %></td>
    </tr>
    <tr>
      <td style="padding: 6px 0; border-top: 1px solid #e2e8f0; font-weight: 600;">Interest Rate</td>
      <td style="padding: 6px 0; border-top: 1px solid #e2e8f0; text-align: right; color: #059669; font-weight: 700;"><%= rate %>%</td>
    </tr>
    <tr>
      <td style="padding: 6px 0; border-top: 1px solid #e2e8f0; font-weight: 600;">New Maturity Date</td>
      <td style="padding: 6px 0; border-top: 1px solid #e2e8f0; text-align: right;"><%= newMatDate %></td>
    </tr>
  </table>
</div>

<p style="color: #64748b; font-size: 13px; text-align: center; margin-bottom: 0; line-height: 1.6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  The maturity amount from the previous cycle has been reinvested as the new principal. You can manage your FDs from your dashboard at any time.
</p>
